# RAGeval — Drop-in LLMOps observability
RAGEVAL_STORE=sqlite
RAGEVAL_DB_PATH=~/.rageval/rageval.db
POSTGRES_URL=
RAGEVAL_OTEL_ENDPOINT=

LLM_JUDGE=anthropic/claude-haiku-4-5
LLM_DEFAULT=groq/llama-3.3-70b-versatile
JUDGE_MODELS=anthropic/claude-haiku-4-5,groq/llama-3.3-70b-versatile,openai/gpt-5-mini

# Embedding model (any SentenceTransformers model). Default is the English baseline.
# For non-English / multilingual corpora switch to BGE-M3 (multilingual, 100+ languages):
#   EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

LOG_LEVEL=INFO

# CORS: comma-separated allowed origins for the API. Empty = "*" (dev). Set in production.
CORS_ALLOWED_ORIGINS=
